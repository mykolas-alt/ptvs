<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005-seed-notification-config" author="Ignas">

        <!-- Global config: notifications enabled, notify all vendors, 30 days in advance -->
        <insert tableName="notification_user_config">
            <column name="id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"/>
            <column name="user_id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="notifications_enabled" valueBoolean="true"/>
            <column name="notify_all" valueBoolean="false"/>
            <column name="days_before_expiry" valueNumeric="30"/>
            <column name="additional_emails" value="boss@imone.lt, info@imone.lt"/>
        </insert>

        <!-- Vendor-specific config: overrides global days to 14, vendor enabled -->
        <insert tableName="notification_vendor_config">
            <column name="id" value="bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"/>
            <column name="user_id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="vendor_id" value="cccccccc-cccc-cccc-cccc-cccccccccccc"/>
            <column name="vendor_enabled" valueBoolean="true"/>
            <column name="days_before_expiry" valueNumeric="14"/>
            <column name="additional_emails" value="vendor@imone.lt"/>
        </insert>

        <!-- Vendor-specific config: no override for days (should fallback to global 30), vendor disabled -->
        <insert tableName="notification_vendor_config">
            <column name="id" value="dddddddd-dddd-dddd-dddd-dddddddddddd"/>
            <column name="user_id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="vendor_id" value="eeeeeeee-eeee-eeee-eeee-eeeeeeeeeeee"/>
            <column name="vendor_enabled" valueBoolean="false"/>
            <column name="days_before_expiry" valueNumeric="null"/>
            <column name="additional_emails" valueComputed="NULL"/>
        </insert>

    </changeSet>

</databaseChangeLog>