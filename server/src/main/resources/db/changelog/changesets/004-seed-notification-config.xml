<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-seed-notification-config" author="casas">
        <insert tableName="notification_config">
            <column name="id" value="99999999-9999-9999-9999-999999999999"/>
            <column name="user_id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="service_id" valueComputed="NULL"/>
            <column name="days_before_expiry" valueNumeric="30"/>
            <column name="additional_emails" value="info@imone.lt, boss@imone.lt"/>
            <column name="enabled" valueBoolean="true"/>
        </insert>
    </changeSet>

</databaseChangeLog>