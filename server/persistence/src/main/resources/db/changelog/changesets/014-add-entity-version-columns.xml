<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="014-add-entity-version-columns" author="mykolas">
        <addColumn tableName="app_user">
            <column name="version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="employee">
            <column name="version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="vendor_contact">
            <column name="version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="third_party_service">
            <column name="version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="employee_aud">
            <column name="version" type="bigint"/>
        </addColumn>

        <addColumn tableName="vendor_contact_aud">
            <column name="version" type="bigint"/>
        </addColumn>

        <addColumn tableName="third_party_service_aud">
            <column name="version" type="bigint"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
