<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="008-recreate-service-notification-config" author="Ignas">
        <dropTable tableName="service_notification_config" cascadeConstraints="true"/>

        <createTable tableName="service_notification_config">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="pk_service_notification_config"/>
            </column>
            <column name="service_id" type="UUID">
                <constraints nullable="false" unique="true"
                             uniqueConstraintName="uk_service_notification_config_service"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="service_notification_config"
                baseColumnNames="service_id"
                referencedTableName="third_party_service"
                referencedColumnNames="id"
                onDelete="CASCADE"
                constraintName="fk_service_notification_config_service"/>
    </changeSet>

</databaseChangeLog>