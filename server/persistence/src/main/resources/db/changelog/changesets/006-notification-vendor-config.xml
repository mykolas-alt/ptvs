<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-create-notification-vendor-config" author="Ignas">
        <createTable tableName="notification_vendor_config">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="pk_notification_vendor_config"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="vendor_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="vendor_enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="days_before_expiry" type="INT"/>
            <column name="additional_emails" type="TEXT"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="notification_vendor_config"
                baseColumnNames="user_id"
                referencedTableName="app_user"
                referencedColumnNames="id"
                onDelete="CASCADE"
                constraintName="fk_notification_vendor_config_user"/>

        <addUniqueConstraint
                tableName="notification_vendor_config"
                columnNames="user_id, vendor_id"
                constraintName="uk_notification_vendor_config_user_vendor"/>
    </changeSet>

</databaseChangeLog>