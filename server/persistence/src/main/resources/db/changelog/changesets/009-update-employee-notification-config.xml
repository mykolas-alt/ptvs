<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="009-recreate-employee-notification-config" author="Ignas">
        <dropTable tableName="employee_notification_config" cascadeConstraints="true"/>

        <createTable tableName="employee_notification_config">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="pk_employee_notification_config"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="service_notification_config_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="days_before_expiry" type="INT"/>
            <column name="additional_emails" type="TEXT"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="employee_notification_config"
                baseColumnNames="employee_id"
                referencedTableName="employee"
                referencedColumnNames="id"
                onDelete="CASCADE"
                constraintName="fk_employee_notification_config_employee"/>

        <addForeignKeyConstraint
                baseTableName="employee_notification_config"
                baseColumnNames="service_notification_config_id"
                referencedTableName="service_notification_config"
                referencedColumnNames="id"
                onDelete="CASCADE"
                constraintName="fk_employee_notification_config_service_config"/>

        <addUniqueConstraint
                tableName="employee_notification_config"
                columnNames="employee_id, service_notification_config_id"
                constraintName="uk_employee_notification_config_employee_service_config"/>
    </changeSet>

</databaseChangeLog>