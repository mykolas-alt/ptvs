<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005-create-employee-notification-config" author="Ignas">
        <createTable tableName="employee_notification_config">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="pk_employee_notification_config"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false" unique="true"
                             uniqueConstraintName="uk_employee_notification_config_employee"/>
            </column>
            <column name="notifications_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="notify_all" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="days_before_expiry" type="INT"/>
            <column name="additional_emails" type="TEXT"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="employee_notification_config"
                baseColumnNames="employee_id"
                referencedTableName="employee"
                referencedColumnNames="id"
                onDelete="CASCADE"
                constraintName="fk_employee_notification_config_employee"/>
    </changeSet>

</databaseChangeLog>