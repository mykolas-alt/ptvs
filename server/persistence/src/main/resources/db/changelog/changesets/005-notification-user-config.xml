<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-create-notification-user-config" author="Ignas">
        <createTable tableName="notification_user_config">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="pk_notification_user_config"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false" unique="true"
                             uniqueConstraintName="uk_notification_user_config_user"/>
            </column>
            <column name="notifications_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="notify_all" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="days_before_expiry" type="INT"/>
            <column name="additional_emails" type="TEXT"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="notification_user_config"
                baseColumnNames="user_id"
                referencedTableName="app_user"
                referencedColumnNames="id"
                onDelete="CASCADE"
                constraintName="fk_notification_user_config_user"/>
    </changeSet>

</databaseChangeLog>