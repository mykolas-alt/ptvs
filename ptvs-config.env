# PTVS Startup Configuration
# This file controls default startup flags for the development environment

# Enable remote debugging for the backend (Spring Boot)
# Set to 'true' to enable JDWP on port 5005
DEBUG_ENABLED=true

# Additional Maven options for backend startup
# Example: -X for debug output, -DskipTests for skipping tests
MAVEN_OPTS=""

# Additional Node options for frontend startup
# Example: --inspect=9229 for Node debugging
NODE_OPTIONS=""
